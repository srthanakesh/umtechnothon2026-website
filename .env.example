# ===========================================
# UMTechnothon 2026 – local development
# ===========================================
# 1. Copy this file to .env in the same folder (project root):
#    copy .env.example .env
# 2. Fill in the values below. Never commit .env to git.
# ===========================================

# ----- Backend (required for server) -----
# Create a project at https://supabase.com (free tier is enough),
# then: Project Settings → API → Project URL and anon public key.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Used to sign JWTs. Use a long random string (e.g. 32+ chars).
# For local dev you can use: JWT_SECRET_KEY=my-local-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key


